{
  "name": "polystore-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:papers": "node scripts/sync-papers.mjs",
    "sync:papers:check": "node scripts/sync-papers.mjs --check",
    "brand:generate": "bash scripts/generate-brand-assets.sh",
    "wasm:build": "command -v wasm-pack >/dev/null 2>&1 || { echo \"wasm-pack not found\"; exit 1; }; cd ../polystore_core && wasm-pack build --release --target web --no-opt --out-dir ../polystore-website/public/wasm --out-name polystore_core && node ../polystore-website/scripts/fix-wasm-gitignore.mjs",
    "wasm:ensure": "if [ \"${POLYSTORE_FORCE_WASM_BUILD:-0}\" = \"1\" ] || [ ! -f public/wasm/polystore_core_bg.wasm ] || [ ! -f public/wasm/polystore_core.js ]; then npm run wasm:build; else echo 'Using existing wasm bundle'; fi",
    "predev": "npm run sync:papers && npm run wasm:ensure",
    "prebuild": "npm run sync:papers",
    "prebuild:app": "npm run sync:papers",
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:app",
    "build:full": "npm run wasm:build && npm run build:app",
    "build:app": "tsc && vite build",
    "ci:build": "if [ -f public/wasm/polystore_core_bg.wasm ] && [ -f public/wasm/polystore_core.js ]; then echo 'Using checked-in wasm bundle'; npm run build:app; else export RUST_DIR=$PWD/.cache/rust && mkdir -p $RUST_DIR && export RUSTUP_HOME=$RUST_DIR && export CARGO_HOME=$RUST_DIR && export PATH=$RUST_DIR/bin:$PATH && if [ ! -f $RUST_DIR/bin/cargo ]; then echo 'Rust not found. Installing...' && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path --default-toolchain stable && rustup target add wasm32-unknown-unknown; else echo 'Rust found in cache!'; fi && npm run build:full; fi",
    "test:unit": "tsx --test $(find src/lib src/api -name '*.test.ts' | sort)",
    "test:integration": "POLYSTORE_E2E=1 tsx --test --test-concurrency=1 $(find src/e2e -name '*.test.ts' | sort)",
    "test:e2e": "playwright test",
    "test:e2e:sparse-browser": "playwright test tests/direct-upload-sparse.spec.ts",
    "perf:prepare": "tsx scripts/benchmark_prepare.ts",
    "perf:prepare-stages": "tsx scripts/benchmark_prepare_stages.ts",
    "perf:prepare-compare": "tsx scripts/benchmark_prepare_compare.ts",
    "perf:user-stage-concurrency": "tsx scripts/benchmark_user_stage_concurrency.ts",
    "perf:msm-windows": "tsx scripts/benchmark_pippenger_windows.ts",
    "perf:kzg-compare": "tsx scripts/benchmark_kzg_commit_compare.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@fontsource/montserrat": "^5.2.6",
    "@libp2p/bootstrap": "^12.0.10",
    "@libp2p/circuit-relay-v2": "^4.1.3",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/identify": "^4.0.10",
    "@libp2p/mplex": "^12.0.10",
    "@libp2p/websockets": "^10.1.2",
    "@multiformats/multiaddr": "^13.0.1",
    "@nil-store/cybergrid-theme": "file:vendor/cybergrid-theme",
    "@noble/hashes": "^2.0.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.90.12",
    "bech32": "^2.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "idb": "^8.0.3",
    "it-length-prefixed": "^10.0.1",
    "kzg-wasm": "^1.0.0",
    "libp2p": "^3.1.2",
    "lucide-react": "^0.555.0",
    "marked": "^12.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0",
    "uint8arraylist": "^2.4.6",
    "uint8arrays": "^5.1.0",
    "viem": "^2.41.2",
    "wagmi": "^2.19.5",
    "zstd-codec": "^0.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.0.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwind-animate": "^0.2.10",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "wasm-pack": "^0.13.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.53.3"
  }
}
