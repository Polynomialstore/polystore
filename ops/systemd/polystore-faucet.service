[Unit]
Description=NilStore devnet faucet (polystore_faucet)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/nilstore/polystore-faucet.env
WorkingDirectory=/opt/nilstore
ExecStart=/bin/bash -lc 'exec "$NIL_FAUCET_BIN"'
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
