# Hub router gateway (polystore_gateway in router mode)

POLYSTORE_ROOT_DIR=/opt/polystore

# Mode
POLYSTORE_GATEWAY_ROUTER=1

# Networking
# For the trusted devnet hub profile (behind HTTPS reverse proxy), bind locally.
# If 8080 is already occupied on your host, choose another local port and keep
# cloudflared/Caddy mapping consistent.
POLYSTORE_LISTEN_ADDR=127.0.0.1:8080

# Chain connectivity
POLYSTORE_CHAIN_ID=<set-me>
POLYSTORE_NODE=tcp://127.0.0.1:26657
POLYSTORE_LCD_BASE=http://127.0.0.1:1317
POLYSTORE_FAUCET_BASE=http://127.0.0.1:8081
POLYSTORE_GAS_PRICES=0.001aatom
POLYSTORE_HOME=/var/lib/polystore/polystorechaind

# Storage (router temp dir)
POLYSTORE_UPLOAD_DIR=/var/lib/polystore/polystore_gateway/router
POLYSTORE_SESSION_DB_PATH=/var/lib/polystore/polystore_gateway/router/sessions.db

# Critical shared secret between router and providers
POLYSTORE_GATEWAY_SP_AUTH=<set-me>

# Binaries + assets
POLYSTORE_GATEWAY_BIN=/opt/polystore/polystore_gateway/polystore_gateway
POLYSTORECHAIND_BIN=/opt/polystore/polystorechain/polystorechaind
POLYSTORE_CLI_BIN=/opt/polystore/polystore_cli/target/release/polystore_cli
POLYSTORE_TRUSTED_SETUP=/opt/polystore/polystorechain/trusted_setup.txt
# Runtime dynamic library path for polystore_core FFI.
LD_LIBRARY_PATH=/opt/polystore/polystore_core/target/release

# Testnet/mainnet posture defaults
POLYSTORE_REQUIRE_ONCHAIN_SESSION=1
POLYSTORE_ENABLE_TX_RELAY=0

# Optional: disable libp2p server for the soft launch (simpler networking).
POLYSTORE_P2P_ENABLED=0
