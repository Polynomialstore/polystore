# Hub chain daemon (polystorechaind)

# Repo root (used by some helpers to resolve relative assets).
POLYSTORE_ROOT_DIR=/opt/polystore

# Chain home directory (MUST be persistent for a multi-week devnet).
POLYSTORE_HOME=/var/lib/polystore/polystorechaind

# Binary paths (build these once and keep stable).
POLYSTORECHAIND_BIN=/opt/polystore/polystorechain/polystorechaind
# Runtime dynamic library path for polystore_core FFI.
LD_LIBRARY_PATH=/opt/polystore/polystore_core/target/release

# Chain settings
POLYSTORE_CHAIN_ID=<set-me>
POLYSTORE_GAS_PRICES=0.001aatom

# Networking
# For the trusted devnet hub profile (behind HTTPS reverse proxy), bind CometBFT RPC locally.
# If you intentionally want RPC reachable without a reverse proxy, override this.
POLYSTORE_RPC_LADDR=tcp://127.0.0.1:26657

# App toggles
POLYSTORE_DISABLE_EVM_MEMPOOL=0
