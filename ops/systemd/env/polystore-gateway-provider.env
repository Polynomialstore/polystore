# Provider gateway (polystore_gateway in provider mode)

POLYSTORE_ROOT_DIR=/opt/polystore

# Networking
POLYSTORE_LISTEN_ADDR=:8091

# Chain connectivity
POLYSTORE_CHAIN_ID=<set-me>
POLYSTORE_NODE=tcp://<hub-host>:26657
POLYSTORE_LCD_BASE=http://<hub-host>:1317
POLYSTORE_GAS_PRICES=0.001aatom

# Provider identity (must exist in the keyring at POLYSTORE_HOME)
POLYSTORE_HOME=/var/lib/polystore/provider/polystorechaind
POLYSTORE_PROVIDER_KEY=provider1

# Storage
POLYSTORE_UPLOAD_DIR=/var/lib/polystore/polystore_gateway/provider/uploads
POLYSTORE_SESSION_DB_PATH=/var/lib/polystore/polystore_gateway/provider/sessions.db

# Shared secret between router and providers
POLYSTORE_GATEWAY_SP_AUTH=<set-me>

# Binaries + assets
POLYSTORE_GATEWAY_BIN=/opt/polystore/polystore_gateway/polystore_gateway
POLYSTORECHAIND_BIN=/opt/polystore/polystorechain/polystorechaind
POLYSTORE_CLI_BIN=/opt/polystore/polystore_cli/target/release/polystore_cli
POLYSTORE_TRUSTED_SETUP=/opt/polystore/polystorechain/trusted_setup.txt
# Runtime dynamic library path for polystore_core FFI.
LD_LIBRARY_PATH=/opt/polystore/polystore_core/target/release

# Optional: disable libp2p server for the soft launch (simpler networking).
POLYSTORE_P2P_ENABLED=0
