# Provider gateway (polystore_gateway in provider mode)

NIL_ROOT_DIR=/opt/nilstore

# Networking
NIL_LISTEN_ADDR=:8091

# Chain connectivity
NIL_CHAIN_ID=<set-me>
NIL_NODE=tcp://<hub-host>:26657
NIL_LCD_BASE=http://<hub-host>:1317
NIL_GAS_PRICES=0.001aatom

# Provider identity (must exist in the keyring at NIL_HOME)
NIL_HOME=/var/lib/nilstore/provider/polystorechaind
NIL_PROVIDER_KEY=provider1

# Storage
NIL_UPLOAD_DIR=/var/lib/nilstore/polystore_gateway/provider/uploads
NIL_SESSION_DB_PATH=/var/lib/nilstore/polystore_gateway/provider/sessions.db

# Shared secret between router and providers
NIL_GATEWAY_SP_AUTH=<set-me>

# Binaries + assets
NIL_GATEWAY_BIN=/opt/nilstore/polystore_gateway/polystore_gateway
NILCHAIND_BIN=/opt/nilstore/polystorechain/polystorechaind
NIL_CLI_BIN=/opt/nilstore/polystore_cli/target/release/polystore_cli
NIL_TRUSTED_SETUP=/opt/nilstore/polystorechain/trusted_setup.txt
# Runtime dynamic library path for polystore_core FFI.
LD_LIBRARY_PATH=/opt/nilstore/polystore_core/target/release

# Optional: disable libp2p server for the soft launch (simpler networking).
NIL_P2P_ENABLED=0
