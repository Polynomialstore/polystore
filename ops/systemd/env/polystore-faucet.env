# Hub faucet service (polystore_faucet)

POLYSTORE_ROOT_DIR=/opt/polystore

POLYSTORE_HOME=/var/lib/polystore/polystorechaind
POLYSTORE_CHAIN_ID=<set-me>

# Networking
# For the trusted devnet hub profile (behind HTTPS reverse proxy), bind locally.
POLYSTORE_LISTEN_ADDR=127.0.0.1:8081

# Token + fees
POLYSTORE_DENOM=stake
POLYSTORE_AMOUNT=1000000000000000000aatom,100000000stake
POLYSTORE_GAS_PRICES=0.001aatom

# Rate limiting
POLYSTORE_COOLDOWN_SECONDS=30

# Optional auth (recommended): when set, requests must include `X-PolyStore-Faucet-Auth: $POLYSTORE_FAUCET_AUTH_TOKEN`.
POLYSTORE_FAUCET_AUTH_TOKEN=<set-me>

# Binaries
POLYSTORECHAIND_BIN=/opt/polystore/polystorechain/polystorechaind
POLYSTORE_FAUCET_BIN=/opt/polystore/polystore_faucet/polystore_faucet
# Runtime dynamic library path for polystore_core FFI (required by polystorechaind tx subprocesses).
LD_LIBRARY_PATH=/opt/polystore/polystore_core/target/release
