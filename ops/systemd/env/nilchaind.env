# Hub chain daemon (nilchaind)

# Repo root (used by some helpers to resolve relative assets).
NIL_ROOT_DIR=/opt/nilstore

# Chain home directory (MUST be persistent for a multi-week devnet).
NIL_HOME=/var/lib/nilstore/nilchaind

# Binary paths (build these once and keep stable).
NILCHAIND_BIN=/opt/nilstore/nilchain/nilchaind
# Runtime dynamic library path for nil_core FFI.
LD_LIBRARY_PATH=/opt/nilstore/nil_core/target/release

# Chain settings
NIL_CHAIN_ID=<set-me>
NIL_GAS_PRICES=0.001aatom

# Networking
# For the trusted devnet hub profile (behind HTTPS reverse proxy), bind CometBFT RPC locally.
# If you intentionally want RPC reachable without a reverse proxy, override this.
NIL_RPC_LADDR=tcp://127.0.0.1:26657

# App toggles
NIL_DISABLE_EVM_MEMPOOL=0
