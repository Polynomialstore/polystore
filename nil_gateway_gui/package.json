{
  "name": "nil_gateway_gui",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "stack:ensure-sp": "bash -lc 'cd .. && NIL_LOCAL_PROVIDER_COUNT=${NIL_LOCAL_PROVIDER_COUNT:-3} NIL_P2P_ENABLED=${NIL_P2P_ENABLED:-0} NIL_P2P_ENABLED_SP=${NIL_P2P_ENABLED_SP:-0} ./scripts/run_local_stack.sh restart-gateway-sp'",
    "stack:ensure-user": "bash -lc 'cd .. && NIL_P2P_ENABLED=${NIL_P2P_ENABLED:-0} ./scripts/run_local_stack.sh restart-gateway-user'",
    "stack:stop-sp": "bash -lc 'cd .. && NIL_LOCAL_PROVIDER_COUNT=${NIL_LOCAL_PROVIDER_COUNT:-3} ./scripts/run_local_stack.sh stop-gateway-sp'",
    "stack:stop-user": "bash -lc 'cd .. && ./scripts/run_local_stack.sh stop-gateway-user'",
    "build-sidecars": "node ./scripts/build_sidecars.mjs",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "desktop": "npm run desktop:user",
    "desktop:user": "npm run stack:stop-user && npm run build-sidecars && npm run tauri dev",
    "desktop:with-sp": "npm run stack:ensure-sp && npm run desktop:user",
    "sp:ensure": "npm run stack:ensure-sp",
    "user:ensure": "npm run stack:ensure-user",
    "sp:stop": "npm run stack:stop-sp",
    "user:stop": "npm run stack:stop-user",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.21.7",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "autoprefixer": "^10.4.23",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
