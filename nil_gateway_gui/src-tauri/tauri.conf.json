{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nil_gateway_gui",
  "version": "0.1.0",
  "identifier": "com.nilstore.nilgateway",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && node ./scripts/build_sidecars.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "nil_gateway_gui",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/nil_gateway",
      "bin/nil_gateway.exe",
      "bin/nil_cli",
      "bin/nil_cli.exe",
      "trusted_setup.txt"
    ]
  }
}
