# Public PolyStore testnet bootstrap defaults for collaborator onboarding.
# Pre-alpha devnet convenience only. Environment variables can override any value here.

POLYSTORE_TESTNET_CHAIN_ID="20260211"
POLYSTORE_TESTNET_WEBSITE_URL="https://polynomialstore.com/#/first-file"
POLYSTORE_TESTNET_EVM_RPC="https://evm.polynomialstore.com"
POLYSTORE_TESTNET_NODE="https://rpc.polynomialstore.com"
POLYSTORE_TESTNET_LCD_BASE="https://lcd.polynomialstore.com"
POLYSTORE_TESTNET_FAUCET_URL="https://faucet.polynomialstore.com/faucet"
POLYSTORE_TESTNET_FAUCET_AUTH_TOKEN=""

# Secrets must be supplied locally, not committed here.
# Shared devnet gas-sponsor credentials are optional helpers for direct nilchaind submission of user-signed EVM intents.
POLYSTORE_TESTNET_TX_SENDER_KEY="faucet"
POLYSTORE_TESTNET_TX_SENDER_MNEMONIC=""
POLYSTORE_TESTNET_GAS_PRICES="0.001aatom"
