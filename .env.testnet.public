# Public NilStore testnet bootstrap defaults for collaborator onboarding.
# Pre-alpha devnet convenience only. Environment variables can override any value here.

NILSTORE_TESTNET_CHAIN_ID="20260211"
NILSTORE_TESTNET_WEBSITE_URL="https://nilstore.org/#/first-file"
NILSTORE_TESTNET_EVM_RPC="https://evm.nilstore.org"
NILSTORE_TESTNET_NODE="https://rpc.nilstore.org"
NILSTORE_TESTNET_LCD_BASE="https://lcd.nilstore.org"
NILSTORE_TESTNET_FAUCET_URL="https://faucet.nilstore.org/faucet"
NILSTORE_TESTNET_FAUCET_AUTH_TOKEN="11e7bb40b8629d639ae52945b709b76fa06f3411802411ee"

# Shared devnet gas-sponsor key for direct nilchaind submission of user-signed EVM intents.
NILSTORE_TESTNET_TX_SENDER_KEY="faucet"
NILSTORE_TESTNET_TX_SENDER_MNEMONIC="course what neglect valley visual ride common cricket bachelor rigid vessel mask actor pumpkin edit follow sorry used divorce odor ask exclude crew hole"
NILSTORE_TESTNET_GAS_PRICES="0.001aatom"
